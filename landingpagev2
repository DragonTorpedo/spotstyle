<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SpotStyle — See It. Love It. Own It.</title>
  <meta name="description" content="Snap any outfit. AI finds every piece in seconds. Shop the exact match or find it at your budget. The fashion companion that actually gets you." />
  <meta property="og:title" content="SpotStyle — See It. Love It. Own It." />
  <meta property="og:description" content="Snap any outfit. AI finds every piece in seconds. Shop instantly." />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />

  <!-- Lucide Icons -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/lucide/0.383.0/umd/lucide.min.js"></script>

  <style>
    /* ─── CSS VARIABLES ─── */
    :root {
      --coral: #E8505B;
      --coral-light: #FFF1EE;
      --coral-dark: #C73A44;
      --peach: #FF8A6B;
      --amber: #F59E0B;
      --amber-light: #FEF3C7;
      --gold: #D4A574;
      --cream: #FFFBF7;
      --warm-gray: #F8F6F3;
      --charcoal: #1A1A2E;
      --text-secondary: #6B6560;
      --text-muted: #9E9892;
      --border: #F0EDE8;
      --radius: 0.75rem;
    }

    /* ─── RESET & BASE ─── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; font-size: 16px; }
    body {
      font-family: 'DM Sans', system-ui, sans-serif;
      background: var(--cream);
      color: var(--charcoal);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }
    button { border: none; background: none; cursor: pointer; font-family: inherit; }

    /* ─── TYPOGRAPHY ─── */
    .font-serif { font-family: 'Playfair Display', Georgia, serif; }
    .text-gradient {
      background: linear-gradient(135deg, #E8505B 0%, #FF8A6B 50%, #F59E0B 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* ─── UTILITIES ─── */
    .glass {
      background: rgba(255,255,255,0.7);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255,255,255,0.3);
    }
    .bg-mesh {
      background:
        radial-gradient(at 20% 20%, rgba(232,80,91,0.08) 0%, transparent 50%),
        radial-gradient(at 80% 80%, rgba(245,158,11,0.06) 0%, transparent 50%),
        radial-gradient(at 50% 50%, rgba(255,138,107,0.04) 0%, transparent 50%);
    }

    /* ─── SCROLLBAR ─── */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--warm-gray); }
    ::-webkit-scrollbar-thumb { background: var(--text-muted); border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--text-secondary); }
    ::selection { background: rgba(232,80,91,0.2); color: var(--charcoal); }

    /* ─── KEYFRAMES ─── */
    @keyframes marquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
    @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
    @keyframes scan-line { 0% { top: 15%; } 100% { top: 85%; } }
    @keyframes shimmer {
      0% { background-position: -200% 0; }
      100% { background-position: 200% 0; }
    }
    @keyframes fade-in-up {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }

    .animate-marquee { animation: marquee 30s linear infinite; }
    .animate-float { animation: float 4s ease-in-out infinite; }
    .animate-pulse { animation: pulse 2s ease-in-out infinite; }

    /* ─── SECTION ANIMATION ─── */
    .reveal {
      opacity: 0;
      transform: translateY(40px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }
    .reveal-delay-4 { transition-delay: 0.4s; }
    .reveal-delay-5 { transition-delay: 0.5s; }

    /* ─── LAYOUT ─── */
    .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
    .container-sm { max-width: 960px; margin: 0 auto; padding: 0 1.5rem; }
    .container-xs { max-width: 720px; margin: 0 auto; padding: 0 1.5rem; }
    section { overflow: hidden; }

    /* ─── NAV ─── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      background: rgba(255,251,247,0.85);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      padding: 1rem 1.5rem;
    }
    .nav-inner {
      max-width: 1200px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between;
    }
    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem; font-weight: 700;
    }
    .nav-logo span { color: var(--coral); }
    .nav-cta {
      padding: 0.6rem 1.4rem;
      border-radius: 999px;
      font-weight: 600; font-size: 0.9rem;
      color: white;
      background: linear-gradient(135deg, #E8505B 0%, #FF8A6B 50%, #F59E0B 100%);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .nav-cta:hover { transform: scale(1.04); box-shadow: 0 8px 24px rgba(232,80,91,0.25); }

    /* ─── HERO ─── */
    #hero {
      min-height: 100vh;
      display: flex; align-items: center;
      position: relative;
    }
    .hero-bg {
      position: absolute; inset: 0;
      background-image: url('data:image/jpeg;base64,');
      background-size: cover; background-position: center;
    }
    .hero-bg::after {
      content: '';
      position: absolute; inset: 0;
      background:
        linear-gradient(to right, rgba(255,251,247,0.95) 0%, rgba(255,251,247,0.80) 50%, rgba(255,251,247,0.40) 100%),
        linear-gradient(to top, rgba(255,251,247,1) 0%, transparent 30%, rgba(255,251,247,0.6) 100%);
    }
    .hero-inner {
      position: relative; z-index: 10;
      width: 100%; padding-top: 7rem; padding-bottom: 4rem;
    }
    .hero-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem; align-items: center;
    }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 0.4rem;
      padding: 0.4rem 1rem;
      border-radius: 999px;
      font-size: 0.85rem; font-weight: 500;
      background: rgba(232,80,91,0.1);
      color: var(--coral);
      border: 1px solid rgba(232,80,91,0.2);
      margin-bottom: 1.5rem;
    }
    .hero-h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.8rem, 5vw, 4.5rem);
      font-weight: 700; line-height: 1.05;
      letter-spacing: -0.02em;
      margin-bottom: 1.5rem;
    }
    .hero-sub {
      font-size: 1.1rem; line-height: 1.7;
      color: var(--text-secondary);
      max-width: 28rem; margin-bottom: 2rem;
    }
    .hero-sub strong { font-weight: 600; color: var(--charcoal); }
    .hero-actions { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; margin-bottom: 2rem; }
    .trust-pills { display: flex; align-items: center; gap: 1.5rem; font-size: 0.85rem; color: var(--text-muted); }
    .trust-pill { display: flex; align-items: center; gap: 0.4rem; }

    /* Download Button */
    .btn-download {
      display: inline-flex; align-items: center; gap: 0.6rem;
      padding: 1rem 2rem;
      border-radius: 1rem; font-weight: 600; font-size: 1rem;
      color: white;
      background: linear-gradient(135deg, #E8505B 0%, #FF8A6B 50%, #F59E0B 100%);
      box-shadow: 0 8px 24px rgba(232,80,91,0.25);
      transition: transform 0.2s, box-shadow 0.2s;
      cursor: pointer; border: none; font-family: inherit;
    }
    .btn-download:hover { transform: scale(1.03); box-shadow: 0 16px 36px rgba(232,80,91,0.35); }
    .btn-download svg { width: 1.1rem; height: 1.1rem; }

    /* Avatars */
    .avatars { display: flex; align-items: center; gap: 0.75rem; }
    .avatar-stack { display: flex; }
    .avatar {
      width: 2rem; height: 2rem; border-radius: 50%;
      border: 2px solid white;
      display: flex; align-items: center; justify-content: center;
      color: white; font-size: 0.7rem; font-weight: 700;
      margin-left: -0.5rem;
    }
    .avatar:first-child { margin-left: 0; }
    .avatars-text .count { font-weight: 700; color: var(--charcoal); font-size: 0.9rem; }
    .avatars-text .label { font-size: 0.75rem; color: var(--text-muted); }

    /* Phone mockup */
    .phone-wrap { display: flex; justify-content: flex-end; position: relative; }
    .phone-frame {
      width: 280px; height: 560px;
      background: #1A1A2E;
      border-radius: 2.5rem;
      border: 6px solid #2a2a3e;
      position: relative; overflow: hidden;
      box-shadow:
        0 50px 100px -20px rgba(26,26,46,0.25),
        0 30px 60px -15px rgba(232,80,91,0.15);
      animation: float 6s ease-in-out infinite;
    }
    .phone-notch {
      position: absolute; top: 0; left: 50%; transform: translateX(-50%);
      width: 8rem; height: 1.6rem;
      background: #2a2a3e; border-radius: 0 0 1rem 1rem;
      z-index: 20;
    }
    .phone-screen {
      position: absolute; inset: 0;
      background-image: url('data:image/png;base64,');
      background-size: cover; background-position: top center;
    }
    .scan-line {
      position: absolute; left: 1rem; right: 1rem; height: 2px; z-index: 10;
      background: linear-gradient(90deg, transparent, #E8505B, transparent);
      animation: scan-line 2s ease-in-out infinite alternate;
    }
    .scan-corner {
      position: absolute; width: 2rem; height: 2rem;
    }
    .scan-corner.tl { top: 3.5rem; left: 1rem; border-top: 2px solid var(--coral); border-left: 2px solid var(--coral); border-radius: 0.4rem 0 0 0; }
    .scan-corner.tr { top: 3.5rem; right: 1rem; border-top: 2px solid var(--coral); border-right: 2px solid var(--coral); border-radius: 0 0.4rem 0 0; }
    .scan-corner.bl { bottom: 5.5rem; left: 1rem; border-bottom: 2px solid var(--coral); border-left: 2px solid var(--coral); border-radius: 0 0 0 0.4rem; }
    .scan-corner.br { bottom: 5.5rem; right: 1rem; border-bottom: 2px solid var(--coral); border-right: 2px solid var(--coral); border-radius: 0 0 0.4rem 0; }
    .phone-overlay {
      position: absolute; bottom: 0; left: 0; right: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.6) 60%, transparent 100%);
      padding: 3.5rem 1rem 1.5rem;
    }
    .scan-status { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem; }
    .dot-pulse {
      width: 0.5rem; height: 0.5rem; border-radius: 50%; background: #34d399;
      animation: pulse 1.5s ease-in-out infinite;
    }
    .scan-label { color: rgba(255,255,255,0.8); font-size: 0.75rem; font-weight: 500; }
    .item-card {
      display: flex; align-items: center; justify-content: space-between;
      background: rgba(255,255,255,0.1);
      backdrop-filter: blur(8px);
      border-radius: 0.5rem; padding: 0.5rem 0.75rem;
      margin-bottom: 0.4rem;
    }
    .item-card:last-child { margin-bottom: 0; }
    .item-name { color: white; font-size: 0.75rem; font-weight: 500; }
    .item-match { color: rgba(255,255,255,0.5); font-size: 0.65rem; }
    .item-price { color: var(--coral); font-weight: 700; font-size: 0.85rem; }

    /* Floating badges */
    .badge-float {
      position: absolute;
      border-radius: 0.75rem; padding: 0.5rem 0.75rem;
      display: flex; align-items: center; gap: 0.5rem;
    }
    .badge-float.b1 { left: -5rem; top: 6rem; animation: float 4s ease-in-out infinite; }
    .badge-float.b2 { right: -3.5rem; top: 12rem; animation: float 5s ease-in-out infinite 1s; }
    .badge-float.b3 { left: -2rem; bottom: 8rem; animation: float 3.5s ease-in-out infinite 0.5s; }
    .badge-icon {
      width: 2rem; height: 2rem; border-radius: 50%;
      display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .badge-icon svg { width: 1rem; height: 1rem; }
    .badge-title { font-size: 0.75rem; font-weight: 600; color: var(--charcoal); white-space: nowrap; }
    .badge-sub { font-size: 0.65rem; color: var(--text-muted); }

    /* ─── TRUST BAR ─── */
    #trust { padding: 1.5rem 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); background: white; }
    .marquee-track { display: flex; white-space: nowrap; }
    .marquee-item { display: inline-flex; align-items: center; gap: 0.75rem; margin: 0 2rem; }
    .marquee-item span { font-size: 0.875rem; color: var(--text-muted); font-weight: 500; }
    .marquee-dot { width: 0.25rem; height: 0.25rem; border-radius: 50%; background: rgba(232,80,91,0.4); }
    .marquee-outer { position: relative; overflow: hidden; }
    .marquee-outer::before, .marquee-outer::after {
      content: ''; position: absolute; top: 0; bottom: 0; width: 6rem; z-index: 1;
    }
    .marquee-outer::before { left: 0; background: linear-gradient(to right, white, transparent); }
    .marquee-outer::after { right: 0; background: linear-gradient(to left, white, transparent); }

    /* ─── SECTIONS SHARED ─── */
    .section-label {
      font-size: 0.75rem; font-weight: 600; text-transform: uppercase;
      letter-spacing: 0.12em; color: var(--coral); margin-bottom: 1rem;
    }
    .section-h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 3.5vw, 3rem);
      font-weight: 700; line-height: 1.15; margin-bottom: 1rem;
    }
    .section-sub {
      font-size: 1.05rem; color: var(--text-secondary); line-height: 1.7;
      max-width: 40rem; margin: 0 auto;
    }
    .text-center { text-align: center; }
    .section-header { text-align: center; margin-bottom: 4rem; }

    /* ─── PROBLEM SECTION ─── */
    #problem { padding: 5rem 0; background: var(--warm-gray); }
    .problem-cards {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem; max-width: 48rem; margin: 0 auto 3.5rem;
    }
    .problem-card {
      background: white; border-radius: 1.25rem; padding: 1.5rem;
      text-align: center; box-shadow: 0 2px 12px rgba(0,0,0,0.04);
      transition: box-shadow 0.3s;
    }
    .problem-card:hover { box-shadow: 0 8px 28px rgba(0,0,0,0.08); }
    .problem-icon {
      width: 3rem; height: 3rem; border-radius: 0.75rem;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 1rem;
    }
    .problem-icon svg { width: 1.4rem; height: 1.4rem; }
    .problem-text { font-weight: 600; color: var(--charcoal); font-size: 0.95rem; }
    .spoiler-pill {
      display: inline-flex; align-items: center; gap: 0.75rem;
      background: white; border-radius: 999px; padding: 0.75rem 1.5rem;
      box-shadow: 0 2px 12px rgba(0,0,0,0.05); border: 1px solid var(--border);
    }
    .spoiler-pill .label { color: var(--text-muted); font-size: 0.875rem; }
    .spoiler-pill .msg { font-weight: 600; color: var(--charcoal); }
    .spoiler-pill svg { width: 1rem; height: 1rem; color: var(--coral); }

    /* ─── HOW IT WORKS ─── */
    #how { padding: 5rem 0; background: white; }
    .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; position: relative; }
    .steps::before {
      content: ''; position: absolute; top: 3.5rem; left: 20%; right: 20%; height: 1px;
      background: linear-gradient(to right, rgba(232,80,91,0.15), rgba(245,158,11,0.15));
    }
    .step { text-align: center; }
    .step-icon-wrap { position: relative; display: inline-flex; margin-bottom: 1.5rem; }
    .step-icon {
      width: 5rem; height: 5rem; border-radius: 1.25rem;
      display: flex; align-items: center; justify-content: center;
      transition: transform 0.3s;
    }
    .step:hover .step-icon { transform: scale(1.1); }
    .step-icon svg { width: 1.75rem; height: 1.75rem; }
    .step-num {
      position: absolute; top: -0.5rem; right: -0.6rem;
      width: 1.6rem; height: 1.6rem; border-radius: 50%;
      background: white; box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.7rem; font-weight: 700;
      background: linear-gradient(135deg, #E8505B, #F59E0B);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .step-num-bg {
      position: absolute; top: -0.5rem; right: -0.6rem;
      width: 1.6rem; height: 1.6rem; border-radius: 50%; background: white;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    .step h3 {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem; font-weight: 700; margin-bottom: 0.25rem;
    }
    .step-subtitle { color: var(--coral); font-weight: 500; font-size: 0.875rem; margin-bottom: 0.75rem; }
    .step p { color: var(--text-secondary); font-size: 0.875rem; line-height: 1.7; max-width: 18rem; margin: 0 auto; }

    /* ─── FEATURES ─── */
    #features { padding: 5rem 0; background: var(--warm-gray); }
    .feature-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
    .feature-card {
      background: white; border-radius: 1.25rem; padding: 1.5rem;
      box-shadow: 0 2px 12px rgba(0,0,0,0.04);
      border: 1px solid transparent;
      transition: all 0.3s; cursor: default;
    }
    .feature-card:hover {
      box-shadow: 0 16px 40px rgba(0,0,0,0.08);
      transform: translateY(-4px);
      border-color: rgba(232,80,91,0.1);
    }
    .feature-icon {
      width: 3rem; height: 3rem; border-radius: 0.75rem;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 1rem; transition: transform 0.3s;
    }
    .feature-card:hover .feature-icon { transform: scale(1.1); }
    .feature-icon svg { width: 1.4rem; height: 1.4rem; }
    .feature-card h3 { font-size: 1rem; font-weight: 700; color: var(--charcoal); margin-bottom: 0.5rem; }
    .feature-card p { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.65; margin-bottom: 0.75rem; }
    .feature-highlight {
      display: inline-flex; align-items: center; gap: 0.3rem;
      color: var(--coral); font-size: 0.85rem; font-weight: 600;
    }
    .feature-highlight svg { width: 0.875rem; height: 0.875rem; }

    /* ─── COMPARISON ─── */
    #comparison { padding: 5rem 0; background: white; }
    table { width: 100%; border-collapse: collapse; font-size: 0.875rem; min-width: 560px; }
    .table-wrap { overflow-x: auto; }
    thead th {
      padding: 1rem 1.25rem; font-weight: 500; font-size: 0.7rem;
      text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted);
    }
    thead th:first-child { text-align: left; }
    thead th:not(:first-child) { text-align: center; }
    thead th.ss-col {
      background: linear-gradient(135deg, rgba(232,80,91,0.08), rgba(245,158,11,0.08));
      color: var(--coral); font-weight: 600; border-radius: 0.75rem 0.75rem 0 0;
    }
    tbody tr { border-bottom: 1px solid rgba(240,237,232,0.5); }
    tbody tr:hover { background: var(--warm-gray); }
    tbody td { padding: 0.9rem 1.25rem; }
    tbody td:first-child { color: var(--charcoal); font-weight: 500; }
    tbody td:not(:first-child) { text-align: center; }
    tbody td.ss-col {
      background: linear-gradient(135deg, rgba(232,80,91,0.04), rgba(245,158,11,0.04));
    }
    .check-yes {
      display: inline-flex; align-items: center; justify-content: center;
      width: 1.5rem; height: 1.5rem; border-radius: 50%; background: #ecfdf5;
    }
    .check-yes svg { width: 0.875rem; height: 0.875rem; color: #059669; }
    .check-no {
      display: inline-flex; align-items: center; justify-content: center;
      width: 1.5rem; height: 1.5rem; border-radius: 50%; background: #f9f9f9;
    }
    .check-no svg { width: 0.875rem; height: 0.875rem; color: #d1d5db; }

    /* ─── STATS ─── */
    #stats { padding: 4rem 0; background: white; }
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; }
    .stat { text-align: center; }
    .stat-icon {
      width: 3rem; height: 3rem; border-radius: 0.75rem;
      background: rgba(232,80,91,0.05); color: var(--coral);
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 0.75rem;
    }
    .stat-icon svg { width: 1.25rem; height: 1.25rem; }
    .stat-value {
      font-family: 'Playfair Display', serif;
      font-size: 2.25rem; font-weight: 700;
      background: linear-gradient(135deg, #E8505B 0%, #FF8A6B 50%, #F59E0B 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text; margin-bottom: 0.25rem;
    }
    .stat-label { font-size: 0.875rem; color: var(--text-muted); font-weight: 500; }

    /* ─── TESTIMONIALS ─── */
